{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "./dist/cli",
    "rootDir": "./src/cli",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["src/cli/**/*"],
  "exclude": ["node_modules", "dist", "tests"],
  "references": [
    { "path": "./tsconfig.core.json" }
  ]
}
